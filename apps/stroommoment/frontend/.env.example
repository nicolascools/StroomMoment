# StroomMoment frontend

# Use http://localhost:8000 when running the frontend dev server directly.
# Leave blank in Docker/production so browser API calls use same-origin /api routes.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional public PoC feedback link. Leave blank to show placeholder text.
# Useful options: Tally form, Google Form, GitHub issue link, or mailto: link.
NEXT_PUBLIC_FEEDBACK_URL=
