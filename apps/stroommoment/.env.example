# StroomMoment Docker Compose defaults
#
# Copy to .env next to docker-compose.yml on a deployment host when overrides are needed.
# Do not commit real .env files.

# Public PoC browser calls should use same-origin /api routes through the Compose router.
NEXT_PUBLIC_API_BASE_URL=

# Local development and public PoC CORS origins for direct backend access.
STROOMMOMENT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://poc.coolsnet.com

# Host path persisted into backend /app/.cache.
STROOMMOMENT_CACHE_HOST_PATH=/var/lib/stroommoment/cache

# Host port exposed by the internal Compose router. Edge-01 proxies to this port.
STROOMMOMENT_HTTP_PORT=8080
