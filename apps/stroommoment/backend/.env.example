# StroomMoment backend
#
# The current MVP uses public, unauthenticated data sources and a server-side file cache.
# Copy this file to .env only when adding local overrides. Do not commit .env.
#
STROOMMOMENT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://poc.coolsnet.com
STROOMMOMENT_CACHE_DIR=.cache
